{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Search": {
    "MaxParallelism": 4
  },
  "ChangeDetection": {
    "ConfirmationWindow": 3
  },
  "Scraper": {
    "BaseUrl": "https://www.solicitors.com",
    "UserAgent": "Mozilla/5.0 (compatible; InfoTrackBot/1.0; +https://infotrack.example)",
    "TimeoutSeconds": 15,
    "DefaultLocations": [
      "London",
      "Manchester",
      "Birmingham",
      "Leeds",
      "Sheffield",
      "Bristol",
      "Liverpool",
      "Nottingham"
    ]
  }
}
